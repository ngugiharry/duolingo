# Stream API credentials
# Reuse from parent .env (../../.env.local or project root .env)
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# OpenAI API key for Realtime
# Required: Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Language teacher settings
# Teacher speaks in this language (default: English)
TEACHER_LANGUAGE=en

# Student learns this language (default: Spanish)
STUDENT_LANGUAGE=es

# LLM Configuration (optional)
# Model to use (default: gpt-4-realtime-preview)
LLM_MODEL=gpt-4-realtime-preview

# Response creativity level 0-1 (default: 0.7)
LLM_TEMPERATURE=0.7

# Audio frames per second (default: 10)
LLM_FPS=10
